
#basic
set folder = "imaps://st1059603@ceid.upatras.gr@mail.ceid.upatras.gr:993"
set smtp_url = "smtp://st1059603@ceid.upatras.gr@mail.ceid.upatras.gr:587"

#use ssl
set ssl_starttls = yes
set ssl_force_tls = yes

#set from
set from = "st1059603@ceid.upatras.gr"
set use_from = yes
set envelope_from = "yes"

#mailboxes
set spoolfile = "+INBOX"
set record = "+Sent"
set trash = "+Trash"
set postponed = "+Drafts"
mailboxes =INBOX =Sent =CEIDPublicMail/students-all =Trash =Drafts =Junk

#sidebar
set sidebar_visible
set sidebar_format = "%B%?F? [%F]?%* %?N?%N/?%S"
set mail_check_stats
bind index,pager B sidebar-toggle-visible
set sidebar_width = 20
set sidebar_short_path

#navigation - mailboxes
bind index,pager \CP sidebar-prev
bind index,pager \CN sidebar-next
bind index,pager \CO sidebar-open

#colors
source colors.muttrc

#refresh
bind index , imap-fetch-mail

							#inspired by Gentoo Wiki

# character set on sent messages
set send_charset="utf-8"

# make sure Vim knows Mutt is a mail client and that a UTF-8 encoded message will be composed
set editor="vim -c 'set syntax=mail ft=mail enc=utf-8'"

# use headercache for IMAP (make sure this is a directory for better performance!)
set header_cache=/var/tmp/.mutt

# IMAP connection settings
set mail_check=60
set imap_keepalive=300

