#######################################################################
# automatically start i3-config-wizard to offer the user to create a
# keysym-based config which used their favorite modifier (alt or windows)
#
# i3-config-wizard will not launch if there already is a config file
# in ~/.config/i3/config (or $XDG_CONFIG_HOME/i3/config if set) or
# ~/.i3/config.
#
# Please remove the following exec line:
#######################################################################
exec i3-config-wizard


# Custom key bindings
bindsym Mod1+Shift+b exec --no-startup-id librewolf
bindsym Mod1+Shift+u exec --no-startup-id qutebrowser
bindsym Mod1+Shift+t exec --no-startup-id thunderbird
bindsym Mod1+Shift+e exec --no-startup-id emacsclient -c -a vim
#jump between workspaces
bindsym Mod1+n workspace next
bindsym Mod1+b workspace prev

# xrandr
# workspace 1 output eDP-1
# workspace 2 output eDP-1
# workspace 3 output eDP-1
# workspace 4 output eDP-1
# workspace 5 output eDP-1
# workspace 6 output HDMI-1
# bindsym Mod1+Shift+a exec --no-startup-id ~/.config/i3/display_setup.sh
# bindsym Mod1+Shift+a exec xrandr --output eDP-1 --off
bindsym Mod1+Shift+a exec xrandr --output eDP-1 --auto
bindsym Mod1+Shift+s exec --no-startup-id /home/angel/.screenlayout/home_monitor_layout.sh &
bindsym Mod1+Shift+d exec --no-startup-id /home/angel/.screenlayout/work_monitor_layout.sh &


# shutdown, reboot, lock screen
set $Locker i3lock -i /home/angel/Pictures/wallpapers/village_tower_houses.png && sleep 1

set $mode_system System (l) lock, (e) logout, (s) suspend, (h) hibernate, (r) reboot, (Shift+s) shutdown
mode "$mode_system" {
    bindsym l exec --no-startup-id $Locker, mode "default"
    bindsym e exec --no-startup-id i3-msg exit, mode "default"
    bindsym s exec --no-startup-id $Locker && systemctl suspend, mode "default"
    bindsym h exec --no-startup-id $Locker && systemctl hibernate, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym Shift+s exec --no-startup-id systemctl poweroff -i, mode "default"

    # back to normal: Enter or Escape
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym Mod1+d mode "$mode_system"






# start polybar
exec_always --no-startup-id /home/angel/.config/polybar/launch.sh

#enabling gaps
